<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
    OpenClaw: VitaMindGo 审核状态检查 (launchd 版本, OpenClaw cron 双保险)
    ====================================================================
    频率: 每 2h 一次 (2/6/10/14/18/22) — offset OpenClaw cron (0/4/8/12/16/20) 1h
    设计: 调 check-vitamindgo-review-with-notify.sh, 拿脚本输出决定弹 Mac 通知
    加载: launchctl load ~/Library/LaunchAgents/com.openclaw.vitamindgo-review.plist
    卸载: launchctl unload ~/Library/LaunchAgents/com.openclaw.vitamindgo-review.plist
    查状态: launchctl list | grep vitamindgo
    查看 log: tail -f ~/.openclaw/workspace/.cache/vitamindgo-review-launchd.log
    ====================================================================
    -->
    <key>Label</key>
    <string>com.openclaw.vitamindgo-review</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/user291981/.openclaw/workspace/scripts/check-vitamindgo-review-with-notify.sh</string>
    </array>

    <!-- 每 2h 一次, offset 1h 从 cron (cron: 0/4/8/12/16/20, launchd: 2/6/10/14/18/22) -->
    <key>StartCalendarInterval</key>
    <array>
        <dict>
            <key>Hour</key>
            <integer>2</integer>
            <key>Minute</key>
            <integer>0</integer>
        </dict>
        <dict>
            <key>Hour</key>
            <integer>6</integer>
            <key>Minute</key>
            <integer>0</integer>
        </dict>
        <dict>
            <key>Hour</key>
            <integer>10</integer>
            <key>Minute</key>
            <integer>0</integer>
        </dict>
        <dict>
            <key>Hour</key>
            <integer>14</integer>
            <key>Minute</key>
            <integer>0</integer>
        </dict>
        <dict>
            <key>Hour</key>
            <integer>18</integer>
            <key>Minute</key>
            <integer>0</integer>
        </dict>
        <dict>
            <key>Hour</key>
            <integer>22</integer>
            <key>Minute</key>
            <integer>0</integer>
        </dict>
    </array>

    <!-- 不在 load 时跑, 等第一次 scheduled 时间 -->
    <key>RunAtLoad</key>
    <false/>

    <!-- 标准输出/错误 → log 文件 -->
    <key>StandardOutPath</key>
    <string>/Users/user291981/.openclaw/workspace/.cache/vitamindgo-review-launchd.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/user291981/.openclaw/workspace/.cache/vitamindgo-review-launchd.err.log</string>

    <!-- 工作目录 (让相对路径稳定) -->
    <key>WorkingDirectory</key>
    <string>/Users/user291981/.openclaw/workspace</string>

    <!-- 环境变量: PATH 必须有, 不然 wrapper 找不到 bash/awk/osascript -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
</dict>
</plist>
